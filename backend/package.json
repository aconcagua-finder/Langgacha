{
  "name": "langgacha-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema src/db/prisma/schema.prisma",
    "db:prepush-word-progress": "prisma db execute --schema src/db/prisma/schema.prisma --file scripts/prepush-word-progress.sql",
    "db:push": "prisma db push --schema src/db/prisma/schema.prisma --accept-data-loss",
    "db:setup": "npm run prisma:generate && npm run db:prepush-word-progress && npm run db:push && tsx scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^9.0.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.3.0",
    "ioredis": "^5.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
