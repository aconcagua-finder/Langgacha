generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id            String   @id @default(uuid())
  language      String
  word          String
  translationRu String
  type          String
  rarity        String
  baseAtk       Int      @map("baseFue")
  baseDef       Int
  colorido      Int
  flavorText    String
  hint          String
  tags          String[]
  canEvolve     Boolean  @default(false)
  imagePrompt   String?

  quizCorrect   String
  quizOptions   String[]

  evolutionData Json?

  createdAt     DateTime @default(now())

  cards         Card[]

  @@unique([language, word], name: "language_word")
}

model Card {
  id              String   @id @default(uuid())
  wordId          String
  word            Word     @relation(fields: [wordId], references: [id])

  atk             Int      @map("fue")
  def             Int

  masteryProgress Int      @default(0)
  condition       String   @default("Normal")
  isEvolved       Boolean  @default(false)

  createdAt       DateTime @default(now())
  lastUsedAt      DateTime @default(now())

  playerId        String?
  player          Player?  @relation(fields: [playerId], references: [id])
}

model Player {
  id        String   @id @default(uuid())
  name      String   @default("Player")
  dust      Int      @default(0) @map("polvo")
  boosterCount  Int      @default(7)
  lastBoosterAt DateTime @default(now())
  lastCraftAt   DateTime?
  pityCounter   Int      @default(0)
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  cards     Card[]
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  player    Player?
}
