generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id            String   @id @default(uuid())
  language      String
  conceptKey    String?
  word          String
  translationRu String
  type          String
  rarity        String
  baseAtk       Int      @map("baseFue")
  baseDef       Int
  colorido      Int
  flavorText    String
  hint          String
  tags          String[]
  canEvolve     Boolean  @default(false)
  imagePrompt   String?

  quizCorrect   String
  quizOptions   String[]

  evolutionData Json?

  createdAt     DateTime @default(now())

  cards         Card[]
  wordProgress  WordProgress[]

  @@unique([language, word], name: "language_word")
}

model Card {
  id              String   @id @default(uuid())
  wordId          String
  word            Word     @relation(fields: [wordId], references: [id])

  atk             Int      @map("fue")
  def             Int

  isEvolved       Boolean  @default(false)

  createdAt       DateTime @default(now())

  playerId        String?
  player          Player?  @relation(fields: [playerId], references: [id])

  raidAttacks     RaidAttack[]
}

model Player {
  id        String   @id @default(uuid())
  name      String   @default("Player")
  dust      Int      @default(0) @map("polvo")
  boosterCount  Int      @default(7)
  lastBoosterAt DateTime @default(now())
  lastCraftAt   DateTime?
  pityCounter   Int      @default(0)
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  cards     Card[]
  wordProgress WordProgress[]
  raidAttacks RaidAttack[]
}

model WordProgress {
  id              String   @id @default(uuid())
  playerId        String
  player          Player   @relation(fields: [playerId], references: [id])
  wordId          String
  word            Word     @relation(fields: [wordId], references: [id])
  xp              Int      @default(0)
  level           Int      @default(0)
  lastReviewedAt  DateTime?
  lastDecayAt     DateTime?

  @@unique([playerId, wordId])
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  player    Player?
}

model RaidDay {
  id            String   @id @default(uuid())
  date          String   @unique
  bossWord      String
  bossTranslationRu String @default("")
  bossHp        Int
  currentHp     Int
  bossAtk       Int
  bossDef       Int
  bossRarity    String
  bossType      String
  bossFlavorText String @default("")
  defeated      Boolean  @default(false)
  createdAt     DateTime @default(now())

  attacks       RaidAttack[]
}

model RaidAttack {
  id        String   @id @default(uuid())
  raidDayId String
  raidDay   RaidDay  @relation(fields: [raidDayId], references: [id])
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id])
  damage    Int
  correct   Boolean
  createdAt DateTime @default(now())

  @@unique([raidDayId, playerId, cardId])
}
